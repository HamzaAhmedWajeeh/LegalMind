# ------------------------------------------------------------
# LLM — Gemni Claude
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------
# Reranker — Cohere
# ------------------------------------------------------------
COHERE_API_KEY=your-cohere-api-key-here

# Cohere rerank model
COHERE_RERANK_MODEL=rerank-english-v3.0

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
POSTGRES_USER=legalmind
POSTGRES_PASSWORD=legalmind_secret_change_in_prod
POSTGRES_DB=legalmind_db

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# Semantic cache similarity threshold (0.0 - 1.0)
# Queries above this cosine similarity score return cached response
SEMANTIC_CACHE_THRESHOLD=0.92

# Cache TTL in seconds (default: 1 hour)
CACHE_TTL_SECONDS=3600

# ------------------------------------------------------------
# Qdrant Vector DB
# ------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=legalmind_docs

# ------------------------------------------------------------
# Ingestion Pipeline Settings
# ------------------------------------------------------------
# Chunk size in tokens
CHUNK_SIZE=512

# Overlap between chunks (10% of chunk size = ~51 tokens)
CHUNK_OVERLAP=51

# Number of chunks to retrieve before reranking
RETRIEVAL_TOP_K=20

# Number of chunks to pass to LLM after reranking
RERANK_TOP_N=5


# Minimum faithfulness score to pass CI/CD gate (0.0 - 1.0)
MIN_FAITHFULNESS_SCORE=0.9

# Number of synthetic QA pairs to generate for golden dataset
GOLDEN_DATASET_SIZE=50

# ------------------------------------------------------------
# App Settings
# ------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=info

# API pagination
MAX_RESULTS_PER_PAGE=50
